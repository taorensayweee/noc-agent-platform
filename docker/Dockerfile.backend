# ITOps Agent Platform - Backend
# Multi-stage build optimized for production and public registry distribution
# Build: docker build -f docker/Dockerfile.backend -t itops-backend:latest .

# ============================================================
# Stage 1: Builder
# ============================================================
FROM node:20-slim AS builder

WORKDIR /app

# Install build dependencies for native modules (better-sqlite3)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy package files first for better layer caching
COPY backend/package.json backend/package-lock.json ./

# Install all dependencies and build native modules
RUN npm ci

# Copy source code
COPY backend/ ./

# Build TypeScript to JavaScript
RUN npm run build

# ============================================================
# Stage 2: Production
# ============================================================
FROM node:20-slim

# Labels for public registry (replace with your actual info)
LABEL maintainer="谭策 <huawei_network@foxmail.com>" \
      org.opencontainers.image.title="ITOps Agent Platform Backend" \
      org.opencontainers.image.description="Enterprise IT Operations Multi-Agent Automation Platform - Backend API Server" \
      org.opencontainers.image.source="https://github.com/qinshihu/itops-agent-platform" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.vendor="谭策" \
      org.opencontainers.image.url="https://www.zjzwfw.cloud/ITOpsAgentinfo"

# Set working directory
WORKDIR /app

# Environment variables
ENV NODE_ENV=production \
    PORT=3001 \
    HOST=0.0.0.0

# Install runtime dependencies (SQLite library for better-sqlite3) and gosu for privilege dropping
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsqlite3-0 \
    gosu \
    && rm -rf /var/lib/apt/lists/*

# Copy built application from builder stage
COPY --from=builder /app/dist ./dist

# Copy node_modules from builder (already compiled with native modules)
COPY --from=builder /app/node_modules ./node_modules

# Copy package.json for reference
COPY backend/package.json ./

# Copy entrypoint script
COPY docker/docker-entrypoint-backend.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Create data directory for SQLite database
RUN mkdir -p /app/data

# Create non-root user
RUN addgroup --system --gid 1001 appgroup && \
    adduser --system --uid 1001 --ingroup appgroup appuser

# Set proper ownership
RUN chown -R appuser:appgroup /app

# Expose API port
EXPOSE 3001

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3001/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Use entrypoint script for proper volume permission handling
ENTRYPOINT ["docker-entrypoint.sh"]

# Start the application
CMD ["node", "dist/app.js"]